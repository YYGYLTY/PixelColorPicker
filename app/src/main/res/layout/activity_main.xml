<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@color/app_background"
    android:fillViewport="true">


    <LinearLayout

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:orientation="vertical"

        android:padding="24dp">


        <TextView

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:text="🎨 PixelColorPicker"

            android:textSize="32sp"

            android:textStyle="bold"

            android:textColor="?android:attr/textColorPrimary"/>


        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:orientation="horizontal"

            android:gravity="center_vertical"

            android:layout_marginTop="8dp"

            android:layout_marginBottom="24dp">


            <TextView

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:text="图片像素化/色板码转换器"

                android:textSize="15sp"

                android:textColor="?android:attr/textColorSecondary"/>


            <TextView

                android:id="@+id/aboutButton"

                android:layout_width="36dp"

                android:layout_height="36dp"

                android:gravity="center"

                android:text="ⓘ"

                android:textSize="18sp"

                android:textColor="?android:attr/textColorPrimary"/>


        </LinearLayout>


        <androidx.cardview.widget.CardView

            android:layout_width="match_parent"

            android:layout_height="320dp"

            android:layout_marginBottom="24dp"

            app:cardCornerRadius="28dp"

            app:cardElevation="0dp"

            app:cardBackgroundColor="@color/card_background">


            <FrameLayout

                android:layout_width="match_parent"

                android:layout_height="match_parent">


                <ImageView

                    android:id="@+id/imagePreview"

                    android:layout_width="match_parent"

                    android:layout_height="match_parent"

                    android:scaleType="centerCrop"/>


                <LinearLayout

                    android:id="@+id/emptyHint"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:layout_gravity="center"

                    android:orientation="vertical"

                    android:gravity="center">


                    <TextView

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="🖼"

                        android:textSize="45sp"/>


                    <TextView

                        android:layout_width="wrap_content"

                        android:layout_height="wrap_content"

                        android:text="点击导入图片"

                        android:textSize="18sp"

                        android:textColor="?android:attr/textColorSecondary"/>


                </LinearLayout>


            </FrameLayout>


        </androidx.cardview.widget.CardView>
        <com.google.android.material.button.MaterialButton

            android:id="@+id/selectImageButton"

            android:layout_width="match_parent"

            android:layout_height="58dp"

            android:text="导入图片"

            android:textSize="16sp"

            android:textStyle="bold"

            android:textColor="#003344"

            android:background="@drawable/button_gradient"

            app:backgroundTint="@null"

            app:cornerRadius="20dp"/>



        <com.google.android.material.button.MaterialButton

            android:id="@+id/exportPixelImageButton"

            android:layout_width="match_parent"

            android:layout_height="58dp"

            android:layout_marginTop="14dp"

            android:text="导出图片"

            android:textSize="16sp"

            android:textStyle="bold"

            android:textColor="#003344"

            android:background="@drawable/button_gradient"

            app:backgroundTint="@null"

            app:cornerRadius="20dp"/>



        <com.google.android.material.button.MaterialButton

            android:id="@+id/pixelButton"

            android:layout_width="match_parent"

            android:layout_height="58dp"

            android:layout_marginTop="14dp"

            android:text="生成 16×16 像素画"

            android:textSize="16sp"

            android:textStyle="bold"

            android:textColor="#003344"

            android:background="@drawable/button_gradient"

            app:backgroundTint="@null"

            app:cornerRadius="20dp"/>



        <com.google.android.material.button.MaterialButton

            android:id="@+id/colorButton"

            android:layout_width="match_parent"

            android:layout_height="58dp"

            android:layout_marginTop="14dp"

            android:text="提取颜色色板"

            android:textSize="16sp"

            android:textStyle="bold"

            android:textColor="#003344"

            android:background="@drawable/button_gradient"

            app:backgroundTint="@null"

            app:cornerRadius="20dp"/>


        <LinearLayout

            android:id="@+id/colorPanel"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="24dp"

            android:padding="16dp"

            android:orientation="vertical"

            android:gravity="center_horizontal"

            android:background="@color/card_background"

            android:visibility="gone">



            <TextView

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:text="🎨 当前16×16色板（点击复制）"

                android:textSize="20sp"

                android:textStyle="bold"

                android:textColor="?android:attr/textColorPrimary"/>



            <HorizontalScrollView

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:layout_marginTop="16dp"

                android:fillViewport="false"

                android:scrollbars="horizontal">


                <TableLayout

                    android:id="@+id/colorTable"

                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"

                    android:stretchColumns="false"/>


            </HorizontalScrollView>



            <com.google.android.material.button.MaterialButton

                android:id="@+id/exportFullButton"

                android:layout_width="match_parent"

                android:layout_height="55dp"

                android:layout_marginTop="16dp"

                android:text="复制完整256色板码"

                android:textSize="15sp"

                android:textStyle="bold"

                android:textColor="#003344"

                android:background="@drawable/button_gradient"

                app:backgroundTint="@null"

                app:cornerRadius="18dp"/>
                android:layout_marginTop="16dp"

                android:text="复制完整256色板码"

                android:textSize="15sp"

                android:textStyle="bold"

                android:textColor="#003344"

                android:background="@drawable/button_gradient"

                app:backgroundTint="@null"

                app:cornerRadius="18dp"/>



            <com.google.android.material.button.MaterialButton

                android:id="@+id/exportColumnButton"

                android:layout_width="match_parent"

                android:layout_height="55dp"

                android:layout_marginTop="12dp"

                android:text="展开分列压缩色板码"

                android:textSize="15sp"

                android:textStyle="bold"

                android:textColor="#003344"

                android:background="@drawable/button_gradient"

                app:backgroundTint="@null"

                app:cornerRadius="18dp"/>




            <LinearLayout

                android:id="@+id/exportPanel"

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:layout_marginTop="16dp"

                android:orientation="vertical"

                android:visibility="gone"

                android:background="@color/card_background"

                android:padding="0dp">


            </LinearLayout>



        </LinearLayout>



    </LinearLayout>



</ScrollView>